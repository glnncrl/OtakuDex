@model OtakuDex.Models.Review

@{
    ViewData["Title"] = "Write a Review";
    var anime = ViewBag.Anime as OtakuDex.Models.Anime;
}

<div class="container mt-4 mb-5" style="max-width:640px;">

    <div class="text-center mb-4">
        <div style="font-size:0.7rem; letter-spacing:3px; text-transform:uppercase; color:#0FFFC1; font-weight:600; margin-bottom:8px;">Review</div>
        <h2 style="font-family:'Space Grotesk',sans-serif; color:#F0F0FF;">@anime?.Title</h2>
        <p style="color:#4A4D6A; font-size:0.85rem;">Share your thoughts about this anime</p>
    </div>

    <div class="dex-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <input type="hidden" asp-for="AnimeId" value="@anime?.Id" />

            <div class="mb-4">
                <label asp-for="ReviewerName" class="form-label">Your Name</label>
                <input asp-for="ReviewerName" class="form-control" placeholder="e.g. Glenn" />
                <span asp-validation-for="ReviewerName" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Rating" class="form-label">Your Rating (1–10)</label>
                <input asp-for="Rating" class="form-control" placeholder="e.g. 9" type="number" min="1" max="10" />
                <span asp-validation-for="Rating" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Content" class="form-label">Your Review</label>
                <textarea asp-for="Content" class="form-control" rows="5" placeholder="Write your review here..."></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-3 mt-4">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    Submit Review
                </button>
                <a asp-controller="Anime" asp-action="Details" asp-route-id="@anime?.Id" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}