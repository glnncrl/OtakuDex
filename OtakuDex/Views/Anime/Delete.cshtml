@model OtakuDex.Models.Anime

@{
    ViewData["Title"] = "Delete Anime";
}

<div class="container mt-4 mb-5" style="max-width:580px;">

    <div class="text-center mb-4">
        <div style="font-size:0.7rem; letter-spacing:3px; text-transform:uppercase; color:#FF2D78; font-weight:600; margin-bottom:8px;">Tracker</div>
        <h2 style="font-family:'Space Grotesk',sans-serif; color:#FF2D78; letter-spacing:1px;">Remove from Tracker</h2>
        <p style="color:#4A4D6A; font-size:0.85rem;">This action cannot be undone</p>
    </div>

    <div class="alert alert-warning text-center mb-4">
        Are you sure you want to remove <strong>@Model.Title</strong> from your tracker?
    </div>

    <div class="dex-card mb-4">
        <div class="row g-3 align-items-center">

            <!-- Cover -->
            <div class="col-3 text-center">
                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl" alt="@Model.Title"
                         style="width:70px; height:100px; object-fit:cover; border-radius:8px; border:1px solid rgba(255,45,120,0.3);" />
                }
                else
                {
                    <div style="width:70px; height:100px; background:rgba(255,45,120,0.08); border-radius:8px; border:1px solid rgba(255,45,120,0.2); display:flex; align-items:center; justify-content:center; margin:0 auto;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(255,45,120,0.4)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" /></svg>
                    </div>
                }
            </div>

            <!-- Info -->
            <div class="col-9">
                <div style="font-family:'Space Grotesk',sans-serif; font-size:1.1rem; font-weight:700; color:#F0F0FF; margin-bottom:8px;">@Model.Title</div>
                <div class="row g-2">
                    <div class="col-6">
                        <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1px; text-transform:uppercase;">Genre</div>
                        <div style="color:#8B8FA8; font-size:0.85rem;">@(Model.Genre ?? "—")</div>
                    </div>
                    <div class="col-6">
                        <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1px; text-transform:uppercase;">Studio</div>
                        <div style="color:#8B8FA8; font-size:0.85rem;">@(Model.Studio ?? "—")</div>
                    </div>
                    <div class="col-6">
                        <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1px; text-transform:uppercase;">Status</div>
                        <div style="color:#8B8FA8; font-size:0.85rem;">@Model.Status</div>
                    </div>
                    <div class="col-6">
                        <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1px; text-transform:uppercase;">Rating</div>
                        <div style="color:#FFD166; font-size:0.85rem; font-weight:600;">
                            @(Model.Rating.HasValue ? $"⭐ {Model.Rating}/10" : "—")
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-danger flex-grow-1" style="display:inline-flex; align-items:center; justify-content:center; gap:6px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /><path d="M10 11v6" /><path d="M14 11v6" /></svg>
                Yes, Remove
            </button>
            <a asp-action="Index" class="btn btn-secondary flex-grow-1 text-center">← Keep It</a>
        </div>
    </form>

</div>