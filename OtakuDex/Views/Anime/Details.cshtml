@model OtakuDex.Models.Anime

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4 mb-5" style="max-width:900px;">

    <!-- Anime Detail Card -->
    <div class="dex-card mb-4">
        <div class="row g-4">

            <!-- Cover -->
            <div class="col-md-3 text-center">
                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl" alt="@Model.Title"
                         style="width:100%; max-width:160px; border-radius:12px; border:1px solid rgba(15,255,193,0.25); box-shadow:0 8px 24px rgba(0,0,0,0.5);" />
                }
                else
                {
                    <div style="width:160px; height:220px; background:rgba(123,97,255,0.1); border-radius:12px; border:1px solid rgba(123,97,255,0.2); display:flex; align-items:center; justify-content:center; margin:0 auto;">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(123,97,255,0.4)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" /></svg>
                    </div>
                }

                <div class="mt-3">
                    @{
                        var badgeClass = Model.Status switch
                        {
                            "Watching" => "badge-watching",
                            "Completed" => "badge-completed",
                            "Dropped" => "badge-dropped",
                            "On Hold" => "badge-onhold",
                            _ => "badge-plan"
                        };
                    }
                    <span class="dex-badge @badgeClass">@Model.Status</span>
                </div>

                @if (Model.Rating.HasValue)
                {
                    <div class="mt-2" style="font-size:1.4rem; font-weight:700; color:#FFD166; display:flex; align-items:center; justify-content:center; gap:4px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="#FFD166" stroke="#FFD166" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                        @Model.Rating<span style="color:#4A4D6A; font-size:0.9rem;">/10</span>
                    </div>
                }
            </div>

            <!-- Info -->
            <div class="col-md-9">
                <h2 style="font-family:'Space Grotesk',sans-serif; color:#F0F0FF; margin-bottom:4px;">@Model.Title</h2>
                <p style="color:#4A4D6A; font-size:0.8rem; letter-spacing:2px; text-transform:uppercase; margin-bottom:1.5rem;">
                    @(Model.Studio ?? "") @(Model.Year.HasValue ? $"· {Model.Year}" : "")
                </p>

                @if (!string.IsNullOrEmpty(Model.Synopsis))
                {
                    <p style="color:#8B8FA8; line-height:1.8; margin-bottom:1.5rem; font-size:0.95rem;">@Model.Synopsis</p>
                }

                <hr style="border-color:rgba(255,255,255,0.06); margin-bottom:1.5rem;" />

                <div class="row g-3">
                    <div class="col-6">
                        <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1.5px; text-transform:uppercase; font-weight:600;">Genre</div>
                        <div style="color:#F0F0FF; margin-top:4px; font-size:0.9rem;">@(Model.Genre ?? "—")</div>
                    </div>
                    <div class="col-6">
                        <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1.5px; text-transform:uppercase; font-weight:600;">Studio</div>
                        <div style="color:#F0F0FF; margin-top:4px; font-size:0.9rem;">@(Model.Studio ?? "—")</div>
                    </div>
                    <div class="col-6">
                        <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1.5px; text-transform:uppercase; font-weight:600;">Episodes</div>
                        <div style="color:#F0F0FF; margin-top:4px; font-size:0.9rem;">@(Model.Episodes?.ToString() ?? "—")</div>
                    </div>
                    <div class="col-6">
                        <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1.5px; text-transform:uppercase; font-weight:600;">Year Released</div>
                        <div style="color:#F0F0FF; margin-top:4px; font-size:0.9rem;">@(Model.Year?.ToString() ?? "—")</div>
                    </div>
                    <div class="col-6">
                        <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1.5px; text-transform:uppercase; font-weight:600;">Your Rating</div>
                        <div style="color:#FFD166; margin-top:4px; font-size:0.9rem; font-weight:600; display:flex; align-items:center; gap:4px;">
                            @if (Model.Rating.HasValue)
                            {
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#FFD166" stroke="#FFD166" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                                @($"{Model.Rating}/10")
                            }
                            else
                            {
                                <span style="color:#4A4D6A;">—</span>
                            }
                        </div>
                    </div>
                    <div class="col-6">
                        <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1.5px; text-transform:uppercase; font-weight:600;">Date Added</div>
                        <div style="color:#F0F0FF; margin-top:4px; font-size:0.9rem;">@Model.DateAdded.ToString("MMMM dd, yyyy")</div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="col-12">
                            <div style="color:#4A4D6A; font-size:0.7rem; letter-spacing:1.5px; text-transform:uppercase; font-weight:600;">Notes</div>
                            <div style="color:#8B8FA8; margin-top:4px; line-height:1.7; font-size:0.9rem;">@Model.Notes</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Genre Tags -->
    <div class="dex-card mb-4">
        <div style="font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:#4A4D6A; font-weight:600; margin-bottom:1rem; display:flex; align-items:center; gap:8px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4A4D6A" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" /><line x1="7" y1="7" x2="7.01" y2="7" /></svg>
            Genre Tags
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:1rem;">
            @if (!Model.AnimeGenres.Any())
            {
                <span style="color:#4A4D6A; font-size:0.82rem;">No genre tags yet.</span>
            }
            @foreach (var ag in Model.AnimeGenres)
            {
                <div style="display:inline-flex; align-items:center; gap:6px; background:rgba(15,255,193,0.08); border:1px solid rgba(15,255,193,0.2); border-radius:20px; padding:4px 12px;">
                    <a asp-controller="Genre" asp-action="Details" asp-route-id="@ag.GenreId"
                       style="color:#0FFFC1; font-size:0.78rem; font-weight:600; text-decoration:none;">@ag.Genre?.Name</a>
                    <form asp-controller="Genre" asp-action="RemoveFromAnime" method="post" style="margin:0; display:inline;">
                        <input type="hidden" name="animeId" value="@Model.Id" />
                        <input type="hidden" name="genreId" value="@ag.GenreId" />
                        @Html.AntiForgeryToken()
                        <button type="submit" style="background:none; border:none; cursor:pointer; padding:0; line-height:1; color:#4A4D6A; display:flex; align-items:center;"
                                onmouseover="this.style.color='#FF2D78'"
                                onmouseout="this.style.color='#4A4D6A'">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                        </button>
                    </form>
                </div>
            }
        </div>

        @{
            var availableGenres = ViewBag.AvailableGenres as IEnumerable<OtakuDex.Models.Genre>;
        }
        @if (availableGenres != null && availableGenres.Any())
        {
            <form asp-controller="Genre" asp-action="AssignToAnime" method="post" style="display:flex; gap:8px; align-items:center;">
                <input type="hidden" name="animeId" value="@Model.Id" />
                @Html.AntiForgeryToken()
                <select name="genreId" class="form-select form-select-sm" style="max-width:200px;">
                    <option value="">Select a genre...</option>
                    @foreach (var g in availableGenres)
                    {
                        <option value="@g.Id">@g.Name</option>
                    }
                </select>
                <button type="submit" class="btn btn-primary btn-sm" style="display:inline-flex; align-items:center; gap:4px;">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    Tag Genre
                </button>
            </form>
        }
        else if (availableGenres != null && !availableGenres.Any() && Model.AnimeGenres.Any())
        {
            <p style="color:#4A4D6A; font-size:0.78rem; margin:0;">All available genres are already tagged.</p>
        }
        else
        {
            <a asp-controller="Genre" asp-action="Index" style="color:#0FFFC1; font-size:0.78rem; text-decoration:none; display:inline-flex; align-items:center; gap:4px;">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                Create genres first
            </a>
        }
    </div>

    <!-- Action Buttons -->
    <div class="d-flex gap-3 mb-5">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning" style="display:inline-flex; align-items:center; gap:6px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
            Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary" style="display:inline-flex; align-items:center; gap:6px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg>
            Back to Tracker
        </a>
    </div>

    <!-- Reviews Section -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <div style="font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:#0FFFC1; font-weight:600; margin-bottom:4px;">Community</div>
            <h3 style="font-family:'Space Grotesk',sans-serif; color:#F0F0FF; font-size:1.4rem; margin:0;">
                Reviews
                <span style="font-size:0.9rem; color:#4A4D6A; font-weight:400; margin-left:8px;">@Model.Reviews.Count review(s)</span>
            </h3>
        </div>
        <a asp-controller="Review" asp-action="Create" asp-route-animeId="@Model.Id"
           class="btn btn-primary btn-sm" style="display:inline-flex; align-items:center; gap:6px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            Write a Review
        </a>
    </div>

    @if (!Model.Reviews.Any())
    {
        <div class="dex-card text-center py-5">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(15,255,193,0.3)" stroke-width="1.5" style="margin-bottom:1rem;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
            <p style="color:#4A4D6A; margin:0;">No reviews yet. Be the first to write one!</p>
        </div>
    }
    else
    {
        @foreach (var review in Model.Reviews.OrderByDescending(r => r.DatePosted))
        {
            <div class="dex-card mb-3">
                <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px;">
                    <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
                        <div style="width:40px; height:40px; border-radius:10px; background:linear-gradient(135deg,#7B61FF,#0FFFC1); display:flex; align-items:center; justify-content:center; font-family:'Space Grotesk',sans-serif; font-weight:700; color:#08090E; font-size:1rem; flex-shrink:0;">
                            @review.ReviewerName[0].ToString().ToUpper()
                        </div>
                        <div>
                            <div style="font-family:'Space Grotesk',sans-serif; font-weight:700; color:#F0F0FF; font-size:0.95rem;">@review.ReviewerName</div>
                            <div style="color:#4A4D6A; font-size:0.75rem;">@review.DatePosted.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>
                    <div style="display:flex; align-items:center; gap:8px;">
                        @if (review.Rating.HasValue)
                        {
                            <span style="color:#FFD166; font-weight:700; font-size:0.9rem; display:flex; align-items:center; gap:4px;">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#FFD166" stroke="#FFD166" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                                @review.Rating/10
                            </span>
                        }
                        <form asp-controller="Review" asp-action="Delete" method="post" style="margin:0;">
                            <input type="hidden" name="id" value="@review.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" style="background:rgba(255,45,120,0.1); border:1px solid rgba(255,45,120,0.25); color:#FF2D78; border-radius:6px; padding:4px 10px; font-size:0.75rem; cursor:pointer; display:flex; align-items:center; gap:4px;"
                                    onmouseover="this.style.background='rgba(255,45,120,0.2)'"
                                    onmouseout="this.style.background='rgba(255,45,120,0.1)'">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /><path d="M10 11v6" /><path d="M14 11v6" /></svg>
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
                <p style="color:#8B8FA8; line-height:1.7; font-size:0.9rem; margin:0;">@review.Content</p>
            </div>
        }
    }

</div>