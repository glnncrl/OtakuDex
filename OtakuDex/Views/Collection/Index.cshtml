@model IEnumerable<OtakuDex.Models.Collection>

@{
    ViewData["Title"] = "Collections";
}

<!-- Hero -->
<div style="position:relative; height:280px; overflow:hidden; display:flex; align-items:center; justify-content:center; margin-bottom:2rem;">
    <div style="position:absolute; inset:0; display:grid; grid-template-columns:repeat(8,1fr); grid-template-rows:repeat(2,1fr); gap:3px; opacity:0.12;">
        @{
            var heroBg = new[] {
                "/images/anime/aot.jpg","/images/anime/fmab.jpg","/images/anime/jjk.jpg","/images/anime/vinland.jpg",
                "/images/anime/spyfamily.jpg","/images/anime/haikyuu.jpg","/images/anime/yourlie.jpg","/images/anime/demonslayer.jpg",
                "/images/anime/demonslayer.jpg","/images/anime/yourlie.jpg","/images/anime/haikyuu.jpg","/images/anime/spyfamily.jpg",
                "/images/anime/vinland.jpg","/images/anime/jjk.jpg","/images/anime/fmab.jpg","/images/anime/aot.jpg",
            };
        }
        @foreach (var bg in heroBg)
        {
            <img src="@bg" style="width:100%; height:100%; object-fit:cover;" />
        }
    </div>
    <div style="position:absolute; inset:0; background:linear-gradient(135deg, rgba(8,9,14,0.92) 0%, rgba(8,9,14,0.75) 50%, rgba(8,9,14,0.92) 100%);"></div>
    <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(8,9,14,0.2) 0%, rgba(8,9,14,0.98) 100%);"></div>
    <div style="position:relative; z-index:1; text-align:center; padding:0 20px;">
        <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(15,255,193,0.08); border:1px solid rgba(15,255,193,0.2); border-radius:20px; padding:5px 16px; font-size:0.68rem; letter-spacing:3px; color:#0FFFC1; text-transform:uppercase; font-weight:600; margin-bottom:1rem;">
            <span style="width:5px; height:5px; background:#0FFFC1; border-radius:50%; display:inline-block; animation:blink 1.5s infinite;"></span>
            Curated Lists
        </div>
        <h1 style="font-family:'Space Grotesk',sans-serif; font-size:2.8rem; font-weight:700; color:#ffffff; line-height:1; margin-bottom:0.75rem;">
            My <span style="color:#0FFFC1;">Collections</span>
        </h1>
        <p style="color:#4A4D6A; font-size:0.85rem; letter-spacing:2px; text-transform:uppercase;">Organize · Curate · Share</p>
    </div>
</div>

<div class="container mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <span style="color:#4A4D6A; font-size:0.85rem;">@Model.Count() collection(s)</span>
        <a asp-action="Create" class="btn btn-primary btn-sm" style="display:inline-flex; align-items:center; gap:6px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            New Collection
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="dex-card text-center py-5">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(15,255,193,0.3)" stroke-width="1.5" style="margin-bottom:1rem;"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" /></svg>
            <p style="color:#4A4D6A; margin:0;">No collections yet. Create your first one!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var collection in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="dex-card h-100" style="transition:all 0.3s ease;"
                         onmouseover="this.style.transform='translateY(-4px)'; this.style.borderColor='rgba(15,255,193,0.25)'"
                         onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(255,255,255,0.06)'">

                        <!-- Mini poster grid -->
                        @{
                            var covers = collection.CollectionItems
                                .Where(ci => !string.IsNullOrEmpty(ci.Anime?.CoverImageUrl))
                                .Take(4)
                                .ToList();
                        }
                        @if (covers.Any())
                        {
                            <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:3px; border-radius:10px; overflow:hidden; margin-bottom:1rem; aspect-ratio:16/7;">
                                @foreach (var cover in covers)
                                {
                                    <img src="@cover.Anime!.CoverImageUrl" style="width:100%; height:100%; object-fit:cover;" />
                                }
                                @for (int i = covers.Count; i < 4; i++)
                                {
                                    <div style="background:rgba(123,97,255,0.08); border:1px solid rgba(123,97,255,0.1);"></div>
                                }
                            </div>
                        }
                        else
                        {
                            <div style="background:rgba(123,97,255,0.06); border:1px solid rgba(123,97,255,0.15); border-radius:10px; height:80px; display:flex; align-items:center; justify-content:center; margin-bottom:1rem;">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(123,97,255,0.3)" stroke-width="1.5"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" /></svg>
                            </div>
                        }

                        <h5 style="font-family:'Space Grotesk',sans-serif; color:#F0F0FF; margin-bottom:4px;">@collection.Name</h5>
                        @if (!string.IsNullOrEmpty(collection.Description))
                        {
                            <p style="color:#4A4D6A; font-size:0.82rem; line-height:1.5; margin-bottom:10px;">@collection.Description</p>
                        }
                        <div style="display:flex; align-items:center; justify-content:space-between; margin-top:auto;">
                            <span style="color:#4A4D6A; font-size:0.75rem;">@collection.CollectionItems.Count anime</span>
                            <div style="display:flex; gap:6px;">
                                <a asp-action="Details" asp-route-id="@collection.Id" class="btn btn-sm btn-info">View</a>
                                <a asp-action="Edit" asp-route-id="@collection.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@collection.Id" class="btn btn-sm btn-danger">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>