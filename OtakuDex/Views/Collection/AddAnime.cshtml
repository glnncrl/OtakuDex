@{
    ViewData["Title"] = "Add Anime to Collection";
    var collection = ViewBag.Collection as OtakuDex.Models.Collection;
    var animes = ViewBag.Animes as IEnumerable<OtakuDex.Models.Anime>;
}

<div class="container mt-4 mb-5" style="max-width:700px;">
    <div class="text-center mb-4">
        <div style="font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:#0FFFC1; font-weight:600; margin-bottom:6px;">Adding to</div>
        <h2 style="font-family:'Space Grotesk',sans-serif; color:#F0F0FF;">@collection?.Name</h2>
        <p style="color:#4A4D6A; font-size:0.85rem;">Select an anime to add to this collection</p>
    </div>

    @if (animes == null || !animes.Any())
    {
        <div class="dex-card text-center py-4">
            <p style="color:#4A4D6A; margin:0;">All anime are already in this collection!</p>
            <a asp-action="Details" asp-route-id="@collection?.Id" class="btn btn-secondary mt-3">← Back</a>
        </div>
    }
    else
    {
        <div class="dex-card p-0 overflow-hidden">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Cover</th>
                        <th>Title</th>
                        <th>Genre</th>
                        <th>Status</th>
                        <th>Rating</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var anime in animes)
                    {
                        <tr>
                            <td style="width:50px;">
                                @if (!string.IsNullOrEmpty(anime.CoverImageUrl))
                                {
                                    <img src="@anime.CoverImageUrl" style="width:38px; height:52px; object-fit:cover; border-radius:4px;" />
                                }
                                else
                                {
                                    <div style="width:38px; height:52px; background:rgba(123,97,255,0.1); border-radius:4px; display:flex; align-items:center; justify-content:center;">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(123,97,255,0.4)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" /></svg>
                                    </div>
                                }
                            </td>
                            <td style="color:#F0F0FF; font-weight:600; font-size:0.875rem;">@anime.Title</td>
                            <td style="color:#8B8FA8; font-size:0.82rem;">@(anime.Genre ?? "—")</td>
                            <td>
                                @{
                                    var bc = anime.Status switch
                                    {
                                        "Watching" => "badge-watching",
                                        "Completed" => "badge-completed",
                                        "Dropped" => "badge-dropped",
                                        "On Hold" => "badge-onhold",
                                        _ => "badge-plan"
                                    };
                                }
                                <span class="dex-badge @bc" style="font-size:0.65rem;">@anime.Status</span>
                            </td>
                            <td style="color:#FFD166; font-size:0.82rem;">@(anime.Rating.HasValue ? $"⭐ {anime.Rating}/10" : "—")</td>
                            <td>
                                <form asp-action="AddAnime" method="post">
                                    <input type="hidden" name="collectionId" value="@collection?.Id" />
                                    <input type="hidden" name="animeId" value="@anime.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-primary btn-sm" style="display:inline-flex; align-items:center; gap:4px;">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                                        Add
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="text-center mt-3">
            <a asp-action="Details" asp-route-id="@collection?.Id" class="btn btn-secondary">← Back to Collection</a>
        </div>
    }
</div>