@model OtakuDex.Models.Collection

@{
    ViewData["Title"] = "Edit Collection";
}

<div class="container mt-4 mb-5" style="max-width:580px;">
    <div class="text-center mb-4">
        <h2 style="font-family:'Space Grotesk',sans-serif; color:#F0F0FF;">Edit Collection</h2>
    </div>
    <div class="dex-card">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="DateCreated" />
            <div class="mb-4">
                <label asp-for="Name" class="form-label">Collection Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-warning flex-grow-1">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}