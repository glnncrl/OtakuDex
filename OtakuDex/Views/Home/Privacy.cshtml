@{
    ViewData["Title"] = "About";
}

<!-- Hero -->
<div style="position:relative; height:220px; overflow:hidden; display:flex; align-items:center; justify-content:center; margin-bottom:3rem;">
    <div style="position:absolute; inset:0; background-image:linear-gradient(rgba(15,255,193,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(15,255,193,0.02) 1px, transparent 1px); background-size:40px 40px;"></div>
    <div style="position:absolute; top:50%; left:30%; width:400px; height:400px; background:rgba(123,97,255,0.06); border-radius:50%; filter:blur(80px);"></div>
    <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(8,9,14,0.1), rgba(8,9,14,0.95));"></div>
    <div style="position:relative; z-index:1; text-align:center;">
        <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(15,255,193,0.08); border:1px solid rgba(15,255,193,0.2); border-radius:20px; padding:5px 16px; font-size:0.68rem; letter-spacing:3px; color:#0FFFC1; text-transform:uppercase; font-weight:600; margin-bottom:0.75rem;">
            About OtakuDex
        </div>
        <h1 style="font-family:'Space Grotesk',sans-serif; font-size:2.5rem; font-weight:700; color:#F0F0FF; margin:0;">About & Privacy</h1>
    </div>
</div>

<div class="container mb-5">

    <!-- Project Info -->
    <div class="dex-card mb-4">
        <div style="font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:#4A4D6A; font-weight:600; margin-bottom:1.5rem; display:flex; align-items:center; gap:8px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4A4D6A" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" /><line x1="3" y1="9" x2="21" y2="9" /><line x1="9" y1="21" x2="9" y2="9" /></svg>
            Project Info
        </div>
        @foreach (var row in new[] {
            ("Project Name", "OtakuDex"),
            ("Type", "Full Stack C# Web Application"),
            ("Course", "COMP 019 \u2014 Applications Development and Emerging Technologies"),
            ("School", "Polytechnic University of the Philippines \u2014 CCIS"),
            ("Framework", "ASP.NET Core MVC (.NET 10)"),
            ("Database", "SQL Server \u2014 OtakuDexDB"),
            ("ORM", "Entity Framework Core"),
            ("Frontend", "Razor Views, Bootstrap 5, Custom CSS"),
            ("Charts", "Chart.js (Analytics Dashboard)"),
            ("Version Control", "Git & GitHub"),
        })
        {
            <div style="display:flex; align-items:flex-start; gap:24px; padding:10px 0; border-bottom:1px solid rgba(255,255,255,0.04);">
                <div style="min-width:200px; color:#4A4D6A; font-size:0.75rem; font-weight:600; letter-spacing:0.5px; padding-top:2px;">@row.Item1</div>
                <div style="color:#F0F0FF; font-size:0.9rem;">@row.Item2</div>
            </div>
        }
    </div>

    <!-- Features -->
    <div class="dex-card mb-4">
        <div style="font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:#4A4D6A; font-weight:600; margin-bottom:1.5rem; display:flex; align-items:center; gap:8px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4A4D6A" stroke-width="2"><polyline points="9 11 12 14 22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
            Key Features
        </div>
        <div class="row g-3">
            @foreach (var feat in new[] {
                new { Icon="<rect x='3' y='3' width='7' height='7'/><rect x='14' y='3' width='7' height='7'/><rect x='14' y='14' width='7' height='7'/><rect x='3' y='14' width='7' height='7'/>", Title="Anime Tracker", Desc="Full CRUD with 5 watch statuses, ratings, and 9 data fields", Color="#0FFFC1" },
                new { Icon="<path d='M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z'/>", Title="Reviews", Desc="Write and manage community reviews per anime with ratings", Color="#A08BFF" },
                new { Icon="<path d='M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z'/>", Title="Collections", Desc="Build custom curated anime lists with cover poster grid", Color="#FFD166" },
                new { Icon="<path d='M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z'/><line x1='7' y1='7' x2='7.01' y2='7'/>", Title="Genre Tags", Desc="Tag anime with genres and browse your tracker by genre", Color="#0FFFC1" },
                new { Icon="<polyline points='22 12 18 12 15 21 9 3 6 12 2 12'/>", Title="Analytics Dashboard", Desc="Live charts: watch status, rating distribution, timeline, top genres", Color="#FF2D78" },
                new { Icon="<path d='M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z'/>", Title="For You", Desc="Weighted recommendation engine powered by your ratings and genres", Color="#FF2D78" },
            })
            {
                <div class="col-md-6">
                    <div style="display:flex; align-items:flex-start; gap:12px; padding:14px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05); border-radius:10px;">
                        <div style="width:36px; height:36px; background:rgba(255,255,255,0.04); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="@feat.Color" stroke-width="2">@Html.Raw(feat.Icon)</svg>
                        </div>
                        <div>
                            <div style="font-family:'Space Grotesk',sans-serif; font-size:0.875rem; font-weight:700; color:#F0F0FF; margin-bottom:3px;">@feat.Title</div>
                            <div style="color:#4A4D6A; font-size:0.78rem; line-height:1.5;">@feat.Desc</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Privacy & Data -->
    <div class="dex-card mb-4">
        <div style="font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:#4A4D6A; font-weight:600; margin-bottom:1.5rem; display:flex; align-items:center; gap:8px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4A4D6A" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
            Privacy & Data
        </div>
        <div class="row g-3">
            @foreach (var item in new[] {
                ("Your data stays local", "All data is stored in your own SQL Server instance. Nothing is sent to external servers."),
                ("No tracking", "OtakuDex does not use analytics, cookies, or any third-party tracking scripts."),
                ("No ads", "This is a personal academic project. There are no advertisements of any kind."),
                ("Full control", "You own your data. Dropping the OtakuDexDB database permanently removes everything."),
            })
            {
                <div class="col-md-6">
                    <div style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.06); border-radius:10px; padding:16px;">
                        <div style="color:#F0F0FF; font-size:0.875rem; font-weight:600; margin-bottom:6px; display:flex; align-items:center; gap:8px;">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#0FFFC1" stroke-width="3"><polyline points="20 6 9 17 4 12" /></svg>
                            @item.Item1
                        </div>
                        <div style="color:#4A4D6A; font-size:0.82rem; line-height:1.6;">@item.Item2</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Repository -->
    <div class="dex-card mb-4">
        <div style="font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:#4A4D6A; font-weight:600; margin-bottom:1.25rem; display:flex; align-items:center; gap:8px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4A4D6A" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" /></svg>
            Repository
        </div>
        <a href="https://github.com/glnncrl/OtakuDex" target="_blank"
           style="display:flex; align-items:center; gap:16px; padding:18px 20px; background:rgba(123,97,255,0.06); border:1px solid rgba(123,97,255,0.2); border-radius:12px; text-decoration:none; color:#F0F0FF;"
           onmouseover="this.style.borderColor='rgba(123,97,255,0.45)'; this.style.background='rgba(123,97,255,0.12)'"
           onmouseout="this.style.borderColor='rgba(123,97,255,0.2)'; this.style.background='rgba(123,97,255,0.06)'">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7B61FF" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" /></svg>
            <div>
                <div style="font-size:0.72rem; color:#4A4D6A; letter-spacing:1px; text-transform:uppercase; font-weight:600; margin-bottom:4px;">OtakuDex on GitHub</div>
                <div style="font-size:1rem; color:#A08BFF; font-weight:700;">github.com/glnncrl/OtakuDex</div>
            </div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4A4D6A" stroke-width="2" style="margin-left:auto;"><line x1="7" y1="17" x2="17" y2="7" /><polyline points="7 7 17 7 17 17" /></svg>
        </a>
    </div>

    <!-- The Team -->
    <div class="dex-card mb-4">
        <div style="font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:#4A4D6A; font-weight:600; margin-bottom:1.5rem; display:flex; align-items:center; gap:8px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4A4D6A" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
            The Team
        </div>

        @{
            var members = new[] {
                new { Initial="L", Name="Lance Joseph M. Dayawon", Color="#7B61FF", GitHub="https://github.com/lancejosephmdayawon/", GitHubLabel="github.com/lancejosephmdayawon", Instagram="https://www.instagram.com/ljdayawon/", InstagramLabel="@ljdayawon", Email="mailto:lancejosephmdayawon@gmail.com", EmailLabel="lancejosephmdayawon@gmail.com" },
                new { Initial="H", Name="Hannah Sophia N. Felonia", Color="#FFD166", GitHub="https://github.com/sophiahannah", GitHubLabel="github.com/sophiahannah", Instagram="https://www.instagram.com/hnhxsphia_/", InstagramLabel="@hnhxsphia_", Email="mailto:hannahsophiafelonia10@gmail.com", EmailLabel="hannahsophiafelonia10@gmail.com" },
                new { Initial="G", Name="Glenn Carlo U. Pabayo", Color="#0FFFC1", GitHub="https://github.com/glnncrl", GitHubLabel="github.com/glnncrl", Instagram="https://www.instagram.com/glnncrl_pby/", InstagramLabel="@glnncrl_pby", Email="mailto:glenn.pabayo@gmail.com", EmailLabel="glenn.pabayo@gmail.com" },
                new { Initial="J", Name="Joshua C. Tanawan", Color="#FF2D78", GitHub="https://github.com/Toshihua", GitHubLabel="github.com/Toshihua", Instagram="https://www.instagram.com/tanawan_josh/", InstagramLabel="@tanawan_josh", Email="mailto:tanawanjoshua28@gmail.com", EmailLabel="tanawanjoshua28@gmail.com" },
            };
        }

        <div class="row g-3">
            @foreach (var m in members)
            {
                <div class="col-md-6">
                    <div style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.06); border-radius:12px; padding:20px; height:100%; transition:all 0.2s ease;"
                         onmouseover="this.style.borderColor='rgba(15,255,193,0.2)'; this.style.background='rgba(15,255,193,0.02)'"
                         onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'; this.style.background='rgba(255,255,255,0.02)'">
                        <div style="display:flex; align-items:center; gap:14px; margin-bottom:16px;">
                            <div style="width:52px; height:52px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-family:'Space Grotesk',sans-serif; font-size:1.3rem; font-weight:700; color:#08090E; flex-shrink:0; background:@m.Color;">
                                @m.Initial
                            </div>
                            <div>
                                <div style="font-family:'Space Grotesk',sans-serif; font-size:1rem; font-weight:700; color:#F0F0FF; line-height:1.2;">@m.Name</div>
                                <div style="color:#4A4D6A; font-size:0.72rem; letter-spacing:1px; text-transform:uppercase; margin-top:3px;">Developer</div>
                            </div>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:8px;">
                            <a href="@m.GitHub" target="_blank" style="display:flex; align-items:center; gap:10px; text-decoration:none; padding:8px 10px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05); border-radius:8px;"
                               onmouseover="this.style.borderColor='rgba(15,255,193,0.2)'"
                               onmouseout="this.style.borderColor='rgba(255,255,255,0.05)'">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4A4D6A" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" /></svg>
                                <span style="color:#8B8FA8; font-size:0.8rem;">@m.GitHubLabel</span>
                            </a>
                            <a href="@m.Instagram" target="_blank" style="display:flex; align-items:center; gap:10px; text-decoration:none; padding:8px 10px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05); border-radius:8px;"
                               onmouseover="this.style.borderColor='rgba(15,255,193,0.2)'"
                               onmouseout="this.style.borderColor='rgba(255,255,255,0.05)'">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4A4D6A" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg>
                                <span style="color:#8B8FA8; font-size:0.8rem;">@m.InstagramLabel</span>
                            </a>
                            <a href="@m.Email" style="display:flex; align-items:center; gap:10px; text-decoration:none; padding:8px 10px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05); border-radius:8px;"
                               onmouseover="this.style.borderColor='rgba(15,255,193,0.2)'"
                               onmouseout="this.style.borderColor='rgba(255,255,255,0.05)'">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4A4D6A" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
                                <span style="color:#8B8FA8; font-size:0.8rem;">@m.EmailLabel</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <p style="color:#4A4D6A; font-size:0.72rem; text-align:center; letter-spacing:0.5px; margin:1.5rem 0 0;">
            Built with ASP.NET Core MVC · Entity Framework Core · SQL Server · Bootstrap 5 · Chart.js
        </p>
    </div>

    <div class="text-center mt-4">
        <a asp-controller="Anime" asp-action="Index" class="btn btn-primary" style="display:inline-flex; align-items:center; gap:8px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
            Go to Tracker
        </a>
    </div>

</div>