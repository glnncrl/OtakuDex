@model OtakuDex.Models.Genre

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <div style="font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:#0FFFC1; font-weight:600; margin-bottom:6px;">Genre</div>
            <h2 style="font-family:'Space Grotesk',sans-serif; color:#F0F0FF; margin-bottom:4px; display:flex; align-items:center; gap:10px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0FFFC1" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" /><line x1="7" y1="7" x2="7.01" y2="7" /></svg>
                @Model.Name
            </h2>
            <p style="color:#4A4D6A; font-size:0.85rem; margin:0;">@Model.AnimeGenres.Count anime tagged with this genre</p>
        </div>
        <a asp-action="Index" class="btn btn-secondary btn-sm" style="display:inline-flex; align-items:center; gap:6px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg>
            Back to Genres
        </a>
    </div>

    @if (!Model.AnimeGenres.Any())
    {
        <div class="dex-card text-center py-5">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(15,255,193,0.3)" stroke-width="1.5" style="margin-bottom:1rem;"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" /></svg>
            <p style="color:#4A4D6A; margin:0;">No anime tagged with <strong style="color:#0FFFC1;">@Model.Name</strong> yet.</p>
            <a asp-controller="Anime" asp-action="Index" class="btn btn-primary btn-sm mt-3" style="display:inline-flex; align-items:center; gap:6px;">
                Go to Tracker
            </a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var ag in Model.AnimeGenres.OrderBy(ag => ag.Anime?.Title))
            {
                <div class="col-6 col-md-3 col-lg-2">
                    <div style="background:#12131F; border:1px solid rgba(255,255,255,0.06); border-radius:14px; overflow:hidden; transition:all 0.3s ease;"
                         onmouseover="this.style.transform='translateY(-4px)'; this.style.borderColor='rgba(15,255,193,0.2)'"
                         onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(255,255,255,0.06)'">
                        <div style="position:relative; aspect-ratio:2/3; overflow:hidden;">
                            @if (!string.IsNullOrEmpty(ag.Anime?.CoverImageUrl))
                            {
                                <img src="@ag.Anime.CoverImageUrl" alt="@ag.Anime.Title"
                                     style="width:100%; height:100%; object-fit:cover;" />
                            }
                            else
                            {
                                <div style="width:100%; height:100%; background:rgba(123,97,255,0.1); display:flex; align-items:center; justify-content:center;">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(123,97,255,0.3)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" /></svg>
                                </div>
                            }
                            <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(8,9,14,0.9) 0%, transparent 60%);"></div>
                        </div>
                        <div style="padding:10px;">
                            <a asp-controller="Anime" asp-action="Details" asp-route-id="@ag.AnimeId"
                               style="font-family:'Space Grotesk',sans-serif; font-size:0.78rem; font-weight:700; color:#F0F0FF; text-decoration:none; line-height:1.3; display:block; margin-bottom:4px;">
                                @ag.Anime?.Title
                            </a>
                            @{
                                var bc = ag.Anime?.Status switch
                                {
                                    "Watching" => "badge-watching",
                                    "Completed" => "badge-completed",
                                    "Dropped" => "badge-dropped",
                                    "On Hold" => "badge-onhold",
                                    _ => "badge-plan"
                                };
                            }
                            <span class="dex-badge @bc" style="font-size:0.6rem;">@ag.Anime?.Status</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>